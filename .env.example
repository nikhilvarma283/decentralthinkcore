# ── Server ────────────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=3000
LOG_LEVEL=info

# ── PostgreSQL ────────────────────────────────────────────────────────────────
DATABASE_URL=postgres://dtcore:dtcore_secret@localhost:5432/decentralthink
DB_POOL_MIN=2
DB_POOL_MAX=10

# ── Vault encryption ─────────────────────────────────────────────────────────
# 64-char hex (32 bytes) — generate: openssl rand -hex 32
VAULT_ENCRYPTION_KEY=replace_with_64_hex_chars

# ── Algorand ──────────────────────────────────────────────────────────────────
ALGORAND_NETWORK=testnet            # testnet | mainnet | localnet
ALGORAND_ALGOD_URL=https://testnet-api.algonode.cloud
ALGORAND_ALGOD_TOKEN=               # empty for public nodes
ALGORAND_INDEXER_URL=https://testnet-idx.algonode.cloud
ALGORAND_MNEMONIC=                  # 25-word mnemonic for signing transactions

# ── OPA ───────────────────────────────────────────────────────────────────────
OPA_URL=http://localhost:8181

# ── Hermes / AI ──────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-replace_me
DEFAULT_MODEL=claude-sonnet-4-6
MAX_TOKENS=4096

# ── SIWE Auth ────────────────────────────────────────────────────────────────
SESSION_SECRET=replace_with_random_secret
SESSION_TTL_SECONDS=3600            # 1 hour

# ── Cost tracking ─────────────────────────────────────────────────────────────
CREDITS_PER_USD=100
