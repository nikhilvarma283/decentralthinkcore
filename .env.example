# ── Server ────────────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=3000
LOG_LEVEL=info

# ── Hermes (Nous Research) — runs inside the container via Ollama ─────────────
# No data leaves your infrastructure. All inference is on-premises.
OLLAMA_URL=http://ollama:11434        # internal docker network address
HERMES_MODEL=nous-hermes2             # nous-hermes2 | nous-hermes2:13b | hermes3
MAX_TOKENS=4096
TEE_TIMEOUT_MS=120000                 # max ms per agent execution

# ── PostgreSQL ────────────────────────────────────────────────────────────────
DATABASE_URL=postgres://dtcore:dtcore_secret@postgres:5432/decentralthink
DB_POOL_MIN=2
DB_POOL_MAX=10

# ── Vault (sovereign — client-side encryption only) ───────────────────────────
# Master key is derived client-side from wallet signature (HKDF).
# Server is a BLIND storage layer and never holds decryption keys.
# No server-side encryption key is needed or used.

# ── Algorand (testnet — switch to mainnet when ready) ─────────────────────────
# Uses free public AlgoNode endpoints — no API key needed for testnet.
# Generate a signing account: npx ts-node -e "const a=require('algosdk');const acc=a.generateAccount();console.log(a.secretKeyToMnemonic(acc.sk),acc.addr)"
ALGORAND_NETWORK=testnet
ALGORAND_SERVER=https://testnet-api.algonode.cloud
ALGORAND_PORT=443
ALGORAND_TOKEN=                     # leave empty for public AlgoNode
ALGORAND_MNEMONIC=                  # 25-word mnemonic — fund with testnet ALGO from dispenser
# Testnet ALGO dispenser: https://testnet.algoexplorer.io/dispenser
# Audit explorer: https://testnet.algoexplorer.io/tx/<blockchain_txid>

# ── OPA ───────────────────────────────────────────────────────────────────────
OPA_URL=http://opa:8181

# ── SIWE Auth ────────────────────────────────────────────────────────────────
SESSION_SECRET=replace_with_random_secret
SESSION_TTL_SECONDS=3600            # 1 hour

# ── Cost tracking ─────────────────────────────────────────────────────────────
# With self-hosted Hermes, cost is infrastructure only (no per-token fees).
# Credits are used for usage metering and fair billing between tenants.
CREDITS_PER_USD=100
