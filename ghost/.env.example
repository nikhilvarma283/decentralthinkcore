# Ghost — production env vars
# Copy to .env and fill in real values (never commit .env)

GHOST_DB_PASSWORD=change_me_strong_password
GHOST_DB_ROOT_PASSWORD=change_me_root_password

# SMTP for Ghost email (membership, newsletters)
# Use Mailgun, Resend, or Brevo free tier
SMTP_HOST=smtp.mailgun.org
SMTP_PORT=587
SMTP_USER=postmaster@mg.decentralthink.com
SMTP_PASS=your_smtp_password
MAIL_FROM=hello@decentralthink.com
